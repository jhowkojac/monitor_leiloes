# PWA Environment Variables

# PWA Configuration
PWA_NAME=Monitor de Leilões
PWA_SHORT_NAME=Leilões MG/SP
PWA_DESCRIPTION=Sistema profissional para monitoramento de leilões
PWA_THEME_COLOR=#c9a227
PWA_BACKGROUND_COLOR=#0f0f12

# Push Notifications (VAPID)
# Gerar chaves em: https://vapidkeys.com/
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@monitorleiloes.com

# PWA Features
PWA_ENABLED=true
PWA_OFFLINE_SUPPORT=true
PWA_PUSH_NOTIFICATIONS=true
PWA_INSTALL_PROMPT=true
