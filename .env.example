# reCAPTCHA v3 Environment Variables

# Google reCAPTCHA v3 Configuration
# Obtenha as chaves em: https://www.google.com/recaptcha/admin/create
RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ENABLED=true

# Para desenvolvimento, use as chaves de teste do Google:
# RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEbQjVQ0MkQ9qM
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
