# Advanced Rate Limiting Environment Variables

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory
RATE_LIMIT_BLOCK_DURATION=300

# Rate Limits per Minute
RATE_LIMIT_DEFAULT_MINUTE=100
RATE_LIMIT_LOGIN_MINUTE=5
RATE_LIMIT_2FA_MINUTE=10
RATE_LIMIT_UPDATE_MINUTE=2
RATE_LIMIT_PUSH_MINUTE=1

# Rate Limits per Hour
RATE_LIMIT_DEFAULT_HOUR=1000
RATE_LIMIT_LOGIN_HOUR=20
RATE_LIMIT_2FA_HOUR=50
RATE_LIMIT_UPDATE_HOUR=10
RATE_LIMIT_PUSH_HOUR=5

# Rate Limits per Day
RATE_LIMIT_DEFAULT_DAY=10000
RATE_LIMIT_LOGIN_DAY=100
RATE_LIMIT_2FA_DAY=200
RATE_LIMIT_UPDATE_DAY=50
RATE_LIMIT_PUSH_DAY=20

# Redis Configuration (if using Redis storage)
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=rate_limit:

# Whitelist IPs (comma separated)
RATE_LIMIT_WHITELIST=127.0.0.1,::1
