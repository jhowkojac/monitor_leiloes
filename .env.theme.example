# Theme Customization Environment Variables

# Theme Configuration
THEME_DEFAULT=default
THEME_ALLOW_CUSTOM=true
THEME_AUTO_SWITCH=false
THEME_SYSTEM_PREFERENCE=default

# Available Themes
THEME_AVAILABLE=default,dark,light,high_contrast

# Custom Theme Limits
THEME_CUSTOM_MAX_PER_USER=5
THEME_CUSTOM_COLORS_MAX=10
THEME_CUSTOM_FONTS_MAX=3

# CSS Variables
THEME_BORDER_RADIUS_DEFAULT=10
THEME_SHADOWS_ENABLED=true
THEME_TRANSITION_DURATION=300

# User Preferences
THEME_SAVE_PREFERENCES=true
THEME_SYNC_WITH_BACKEND=true
THEME_DETECT_SYSTEM_PREFERENCE=true

# Performance
THEME_LAZY_LOAD=true
THEME_CACHE_DURATION=3600
THEME_PRELOAD_THEMES=default,dark,light
