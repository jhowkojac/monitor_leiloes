# Advanced Analytics Environment Variables

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_STORAGE=memory
ANALYTICS_RETENTION_DAYS=90

# Event Tracking
ANALYTICS_TRACK_PAGE_VIEWS=true
ANALYTICS_TRACK_CLICKS=true
ANALYTICS_TRACK_SEARCHES=true
ANALYTICS_TRACK_FILTERS=true
ANALYTICS_TRACK_PERFORMANCE=true
ANALYTICS_TRACK_SCROLL_DEPTH=true

# Performance Metrics
ANALYTICS_PERFORMANCE_SAMPLE_RATE=0.1
ANALYTICS_PERFORMANCE_THRESHOLD_SLOW=2000
ANALYTICS_PERFORMANCE_THRESHOLD_VERY_SLOW=5000

# Real-time Analytics
ANALYTICS_REAL_TIME_WINDOW=5
ANALYTICS_SESSION_TIMEOUT=1800

# Privacy and Compliance
ANALYTICS_ANONYMIZE_IPS=true
ANALYTICS_STORE_USER_AGENT=true
ANALYTICS_GDPR_COMPLIANT=true

# Export Configuration
ANALYTICS_EXPORT_FORMATS=json,csv
ANALYTICS_MAX_EXPORT_DAYS=365

# API Configuration
ANALYTICS_API_ENDPOINT=/api/analytics/track
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=30
